<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>com.github.jvcByte.clip_pop</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>
  <name>Clip Pop</name>
  <summary>Clipboard manager for the COSMIC™ desktop</summary>
  <description>
    <p>
      Clip Pop is a clipboard manager built natively for the COSMIC™ desktop environment.
      It keeps a searchable history of everything you copy, lets you re-paste any previous
      entry with a single click, and persists your history across reboots.
    </p>
    <ul>
      <li>Searchable clipboard history</li>
      <li>Persistent history across sessions</li>
      <li>Configurable history size and poll interval</li>
      <li>Delete individual entries or clear all at once</li>
    </ul>
  </description>
  <url type="homepage">https://github.com/jvcByte/clip_pop</url>
  <url type="vcs-browser">https://github.com/jvcByte/clip_pop</url>
  <url type="bugtracker">https://github.com/jvcByte/clip_pop/issues</url>
  <launchable type="desktop-id">com.github.jvcByte.clip_pop.desktop</launchable>
  <provides>
    <binary>clip_pop</binary>
  </provides>
  <requires>
    <display_length compare="ge">360</display_length>
  </requires>
  <supports>
    <control>keyboard</control>
    <control>pointing</control>
  </supports>
  <categories>
    <category>Utility</category>
  </categories>
  <keywords>
    <keyword>clipboard</keyword>
    <keyword>copy</keyword>
    <keyword>paste</keyword>
    <keyword>history</keyword>
    <keyword>COSMIC</keyword>
  </keywords>
  <content_rating type="oars-1.1" />
  <releases>
